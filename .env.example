# Telegram bot token (@BotFather dan oling)
BOT_TOKEN=replace-with-a-new-token-from-botfather

# Bot username (@ belgisisiz), guruhga qo'shish deep-link uchun
BOT_USERNAME=quizedubasebot

# Django
# SECRET_KEY yaratish:  python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-generate-with-the-command-above
# Production'da har doim False! Faqat lokal ishlab chiqishda True qiling.
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost
# HTTPS domeningiz (POST formalar uchun), masalan: https://panel.example.uz
# CSRF_TRUSTED_ORIGINS=

# Bitta savol partiyasidagi (qism) maksimal savollar — importda guruhlash uchun
QUESTIONS_PER_PART=50

# --- Bot parallellik sozlamalari (odatda tegmasa ham bo'ladi) ---
# Bir vaqtda qayta ishlanadigan Telegram update'lar soni
# BOT_TASKS_CONCURRENCY=200
# DB operatsiyalari uchun ishchi thread'lar soni
# BOT_DB_THREADS=32

# --- Xavfsizlik ---
# nginx kabi reverse-proxy orqasida ishlasa True (default), proxy'siz False.
# TRUST_PROXY=True
# Log darajasi: DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO

# --- Ma'lumotlar bazasi ---
# Production: boshqariladigan PostgreSQL ulanish satri (tavsiya).
# Belgilansa, SQLite o'rniga shu ishlatiladi.
# DATABASE_URL=postgres://user:parol@host:25060/dbname?sslmode=require

# Dev (SQLite) uchun baza fayli yo'li. MUHIM: iCloud/Dropbox/Desktop sinxronidan TASHQARIDA bo'lsin!
# Bo'sh qoldirilsa: loyiha ichidagi data/sql/db.sqlite3 ishlatiladi (sinxron bo'lsa xavfli).
# DB_PATH=/Users/siz/quizbot-data/db.sqlite3
